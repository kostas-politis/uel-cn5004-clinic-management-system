<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<DialogPane
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="uk.ac.uel.clinicmanagementsystem.controller.AppointmentDialogController"
    styleClass="table-dialog"
>
    <content>
        <VBox>
            <Label text="Doctor:" />
            <ComboBox fx:id="doctorComboBox" maxWidth="Infinity" />
            <Label fx:id="doctorErrorLabel" />

            <Label text="Patient:" />
            <ComboBox fx:id="patientComboBox" maxWidth="Infinity" />
            <Label fx:id="patientErrorLabel" />

            <Label text="Date / Time:" />
            <HBox spacing="8" alignment="CENTER_LEFT">
                <DatePicker
                    fx:id="datePicker"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                />
                <Spinner fx:id="hourSpinner" minWidth="60" maxWidth="60" />
                <Spinner fx:id="minuteSpinner" minWidth="60" maxWidth="60" />
            </HBox>
        </VBox>
    </content>
    <buttonTypes>
        <ButtonType fx:constant="OK" />
        <ButtonType fx:constant="CANCEL" />
    </buttonTypes>
</DialogPane>
